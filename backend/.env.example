# 复制为 .env 后由 uvicorn / 本地工具加载（可选用 python-dotenv，当前通过 shell export 亦可）
# （可选）与前台/镜像 tag 对齐的 API 版本字符串，会出现在 OpenAPI 与 GET /api/health 的 api_version
# APP_VERSION=1.0.0
# （可选）CI 注入供 /api/health 返回，便于回滚时对账：GIT_SHA、GITHUB_SHA、BUILD_ID
# GIT_SHA=
# BUILD_ID=
# 生产必须设置 ENVIRONMENT=production（会启用 JWT 强校验，且不再覆盖已存在演示账号的密码哈希）
# ENVIRONMENT=production
# 发布前可在 backend 目录执行：PYTHONPATH=. python scripts/verify_release_env.py（生产时校验 JWT；PG 则 SELECT 1；见 docs/手册-C）
# 下一行仅为示例：线上须换为 ≥24 字符随机串；勿把本文件字面量复制到生产（SEC-01 / env_guard 会拒绝弱值）
JWT_SECRET=请改为足够长的随机串
# sitemap.xml / robots.txt 中的绝对 URL 根（不要尾斜杠）。生产应与前台构建变量 VITE_PUBLIC_SITE_URL 同域。
# PUBLIC_SITE_URL=https://www.example.com
# 不设 DATABASE_URL 时使用 data/app.db（SQLite）。设为 postgresql:// 或 postgres:// 时走 PostgreSQL（需安装 psycopg，见 requirements.txt）：
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_tools_hub
# 可选：管理端「发送邮件」真实 SMTP（均未设则返回 stub: true）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=1
# 逗号分隔的完整源（含协议与端口）。跨域部署时生产必填；留空则仅匹配本机/私网 Origin 正则。
# ENVIRONMENT=production 且未设置时进程启动会打印 WARN（见 app/env_guard.py）。
# ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-domain.com
# 若必须公开 API 测试且无需 Cookie，可设为 *（此时 allow_credentials 为 false）
# ALLOWED_ORIGINS=*
# （可选）管理端「AI SEO 分析」全局 API Key（优先于库内 ai_insight_llm_provider 各行的 api_key / api_key_env_name）
# AI_INSIGHT_LLM_API_KEY=
# AI SEO 页面维度：默认 0＝全站逐页（catalog∪page_seo 并集全注入）；设正整数则只取前 N 条以控 token（见 P-AI-04）
# AI_INSIGHT_PAGE_SEO_MAX_PATHS=0
# SEO 快照 JSON 注入模板时的最大字符数（全站页多时调大；过小会在 …(truncated) 处截断）
# AI_INSIGHT_SEO_SNAPSHOT_MAX_CHARS=400000
# AI_INSIGHT_TRAFFIC_WINDOW_DAYS=7
# AI_INSIGHT_TRAFFIC_TOP_PATHS=20
# 多 worker 共享限流（不设则进程内滑动窗口，见 P-AI-06）
# AI_INSIGHT_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# 每管理员限流窗口与次数（与 POST /run 一致；快照 ai_insight_snapshot_env_limits 会镜像）
# AI_INSIGHT_RATE_LIMIT_WINDOW_SEC=300
# AI_INSIGHT_RATE_LIMIT_MAX_CALLS=10
# —— v2.x：敏感写库二次确认（批准 / 应用 SEO 任务 / 回滚）；不设或留空则关闭
# AI_INSIGHT_STEP_UP_MODE=shared_secret
# AI_INSIGHT_STEP_UP_SHARED_SECRET=与运维约定的一次性口令
# 或改为登录密码复核：
# AI_INSIGHT_STEP_UP_MODE=login_password
# 独立进程消费 defer_llm 的 pending（多实例 API 推荐；见 scripts/ai_insight_pending_worker.py）
# （无环境变量开关；直接运行脚本或 systemd/cron --once）
# 进程内爬虫定时器：设为 0 / false / off 可关闭（默认开启，每分钟检查一次各数据源的间隔与每日条数）
# CRAWLER_SCHEDULER_ENABLED=1
# —— AI SEO 进程内日更（与爬虫调度并列；默认关闭，避免误调用 LLM）
# AI_INSIGHT_DAILY_SCHEDULER_ENABLED=1
# 服务器本地「几点起」才允许触发当日首次 run（0–23，默认 3）
# AI_INSIGHT_DAILY_RUN_HOUR_LOCAL=3
# 可选：固定提示词配置 id / LLM 连接 id（不设则与后台默认配置、默认连接一致）
# AI_INSIGHT_DAILY_CONFIG_ID=
# AI_INSIGHT_DAILY_PROVIDER_ID=
# —— UGC 文本：逗号分隔黑名单（大小写不敏感）。纯 ASCII「单词形」片段（字母数字与中间 -/_）按两侧非字母数字边界匹配，减误伤；含空格/中文等仍子串。命中则 POST /api/submissions/tool 返回 400 ugc_blocked_substring；不设则关闭
# UGC_BLOCKED_SUBSTRINGS=
# —— 公开埋点限流（按客户端 IP；信任 X-Forwarded-For 最左段）。POST /api/track 与 POST /api/track/outbound 分别计数；超限 429 rate_limited_track
# TRACK_PV_RATE_LIMIT_WINDOW_SEC=60
# TRACK_PV_RATE_LIMIT_MAX=300
# TRACK_OUTBOUND_RATE_LIMIT_WINDOW_SEC=60
# TRACK_OUTBOUND_RATE_LIMIT_MAX=120
# 多 worker 可与 AI SEO 共用 Redis 做固定窗口：TRACK_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# —— AI SEO 任务派发（预留）：当前均为进程内与独立 worker 脚本；未来若接 Celery/RQ 可约定例如 AI_INSIGHT_QUEUE_MODE=celery
# AI_INSIGHT_QUEUE_MODE=inline
# —— 工具列表推荐分重算：进程内定时任务间隔（秒）；≤0 关闭。首次启动约 20s 后跑一轮，之后按间隔执行（须 site_json recommend_algo_v1.enabled=true）
# RECOMMEND_SCORE_INTERVAL_SEC=3600
